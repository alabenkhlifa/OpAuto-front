generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────

enum UserRole {
  OWNER
  STAFF
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  VIP
  BLOCKED
}

enum EmployeeRole {
  MECHANIC
  ELECTRICIAN
  BODYWORK_SPECIALIST
  TIRE_SPECIALIST
  MANAGER
  RECEPTIONIST
  APPRENTICE
}

enum EmployeeDepartment {
  MECHANICAL
  BODYWORK
  ELECTRICAL
  TIRE_ALIGNMENT
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  INACTIVE
}

enum MaintenanceStatus {
  PENDING
  DIAGNOSED
  WAITING_APPROVAL
  WAITING_PARTS
  IN_PROGRESS
  QUALITY_CHECK
  COMPLETED
  CANCELLED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ApprovalType {
  MAINTENANCE
  INVOICE
  PURCHASE_ORDER
  DISCOUNT
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  CHECK
  MOBILE_PAYMENT
}

enum AiActionKind {
  REMINDER_SMS
  DISCOUNT_SMS
}

enum AiActionStatus {
  DRAFT
  APPROVED
  SENT
  FAILED
  SKIPPED
  REDEEMED
  EXPIRED
}

enum DiscountKind {
  PERCENT
  AMOUNT
}

enum NotificationType {
  APPOINTMENT_REMINDER
  APPOINTMENT_CREATED
  APPOINTMENT_UPDATED
  MAINTENANCE_STATUS
  APPROVAL_REQUEST
  APPROVAL_RESPONSE
  INVOICE_CREATED
  INVOICE_OVERDUE
  LOW_STOCK
  EMPLOYEE_SCHEDULE
  SYSTEM
}

enum AssistantMessageRole {
  USER
  ASSISTANT
  TOOL
  SYSTEM
}

enum AssistantToolCallStatus {
  PENDING_APPROVAL
  APPROVED
  DENIED
  EXECUTED
  FAILED
  EXPIRED
}

enum AssistantBlastTier {
  READ
  AUTO_WRITE
  CONFIRM_WRITE
  TYPED_CONFIRM_WRITE
}

enum NumberingResetPolicy {
  NEVER
  YEARLY
  MONTHLY
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
}

enum CreditNoteStatus {
  ISSUED
  CANCELLED
}

enum CounterKind {
  INVOICE
  QUOTE
  CREDIT_NOTE
}

enum DeliveryChannel {
  EMAIL
  WHATSAPP
  BOTH
}

enum DeliveryStatus {
  PENDING
  SENT
  FAILED
  VIEWED
}

// ── Models ──────────────────────────────────────────────

model Garage {
  id              String   @id @default(uuid())
  name            String
  address         String?
  phone           String?
  email           String?
  logo            String?
  specializations String[] // MECHANICAL, BODYWORK, ELECTRICAL, TIRE_ALIGNMENT
  businessHours   Json? // { mon: { open: "08:00", close: "18:00" }, ... }
  currency        String   @default("TND")
  taxRate         Float    @default(19.0)

  // Fiscal / invoicing configuration
  mfNumber                String? // matricule fiscal
  rib                     String?
  bankName                String?
  logoUrl                 String?
  defaultPaymentTermsDays Int                  @default(30)
  numberingPrefix         String               @default("INV")
  numberingResetPolicy    NumberingResetPolicy @default(YEARLY)
  numberingDigitCount     Int                  @default(4)
  defaultTvaRate          Float                @default(19)
  fiscalStampEnabled      Boolean              @default(true)
  // Phase 3.2 — discount audit trail. When an invoice-level or line-level
  // discount exceeds this percentage, the request must include a
  // `discountReason` and an OWNER `discountApprovedBy` userId, and a
  // DiscountAuditLog row is written. Default 5% matches the pre-decided
  // policy in the overhaul plan.
  discountAuditThresholdPct Float              @default(5)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                  User[]
  customers              Customer[]
  cars                   Car[]
  appointments           Appointment[]
  employees              Employee[]
  maintenanceJobs        MaintenanceJob[]
  invoices               Invoice[]
  parts                  Part[]
  suppliers              Supplier[]
  approvals              Approval[]
  notifications          Notification[]
  garageModules          GarageModule[]
  aiActions              AiAction[]
  assistantConversations AssistantConversation[]
  quotes                 Quote[]
  creditNotes            CreditNote[]
  invoiceCounters        InvoiceCounter[]
  serviceCatalog         ServiceCatalog[]

  @@map("garages")
}

model User {
  id          String    @id @default(uuid())
  garageId    String
  email       String?   @unique
  username    String?   @unique
  password    String
  firstName   String
  lastName    String
  role        UserRole  @default(STAFF)
  avatar      String?
  phone       String?
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  garage                     Garage                  @relation(fields: [garageId], references: [id], onDelete: Cascade)
  preferences                UserPreference?
  approvedAiActions          AiAction[]              @relation("AiActionApprover")
  assistantConversations     AssistantConversation[]
  approvedAssistantToolCalls AssistantToolCall[]     @relation("AssistantToolCallApprover")

  @@map("users")
}

model UserPreference {
  id                   String   @id @default(uuid())
  userId               String   @unique
  emailNotifications   Boolean  @default(true)
  smsNotifications     Boolean  @default(false)
  browserNotifications Boolean  @default(true)
  language             String?
  theme                String? // 'dark' | 'light'
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model Customer {
  id          String         @id @default(uuid())
  garageId    String
  firstName   String
  lastName    String
  email       String?
  phone       String
  address     String?
  // Tunisian matricule fiscal — required on accountant exports for
  // B2B customers. Optional because many private customers have none.
  mfNumber    String?
  status      CustomerStatus @default(ACTIVE)
  loyaltyTier String? // bronze, silver, gold, platinum
  totalSpent  Float          @default(0)
  visitCount  Int            @default(0)
  smsOptIn    Boolean        @default(true)
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  garage       Garage        @relation(fields: [garageId], references: [id], onDelete: Cascade)
  cars         Car[]
  appointments Appointment[]
  invoices     Invoice[]
  aiActions    AiAction[]
  quotes       Quote[]

  @@map("customers")
}

model Car {
  id              String    @id @default(uuid())
  garageId        String
  customerId      String
  make            String
  model           String
  year            Int
  vin             String?
  licensePlate    String
  color           String?
  mileage         Int?
  engineType      String? // petrol, diesel, electric, hybrid
  transmission    String? // manual, automatic
  lastServiceDate DateTime?
  nextServiceDate DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  garage          Garage           @relation(fields: [garageId], references: [id], onDelete: Cascade)
  customer        Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
  maintenanceJobs MaintenanceJob[]
  invoices        Invoice[]
  quotes          Quote[]

  @@map("cars")
}

model Appointment {
  id          String            @id @default(uuid())
  garageId    String
  customerId  String
  carId       String
  employeeId  String?
  title       String
  description String?
  status      AppointmentStatus @default(SCHEDULED)
  startTime   DateTime
  endTime     DateTime
  type        String? // oil-change, brake-service, inspection, etc.
  priority    String? // low, medium, high, urgent
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  garage   Garage    @relation(fields: [garageId], references: [id], onDelete: Cascade)
  customer Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  car      Car       @relation(fields: [carId], references: [id], onDelete: Cascade)
  employee Employee? @relation(fields: [employeeId], references: [id])
  invoices Invoice[]

  @@map("appointments")
}

model Employee {
  id                String             @id @default(uuid())
  garageId          String
  userId            String?
  firstName         String
  lastName          String
  email             String?
  phone             String?
  role              EmployeeRole       @default(MECHANIC)
  department        EmployeeDepartment @default(MECHANICAL)
  status            EmployeeStatus     @default(ACTIVE)
  hireDate          DateTime
  hourlyRate        Float?
  schedule          Json? // Weekly schedule
  skills            String[]
  avatar            String?
  customerRating    Float? // 0-5 scale, customer satisfaction
  isAvailable       Boolean            @default(true)
  unavailableReason String?
  unavailableUntil  DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  garage              Garage               @relation(fields: [garageId], references: [id], onDelete: Cascade)
  appointments        Appointment[]
  maintenanceJobs     MaintenanceJob[]
  invoiceLineItems    InvoiceLineItem[]
  quoteLineItems      QuoteLineItem[]
  creditNoteLineItems CreditNoteLineItem[]

  @@map("employees")
}

model MaintenanceJob {
  id             String            @id @default(uuid())
  garageId       String
  carId          String
  employeeId     String?
  title          String
  description    String?
  status         MaintenanceStatus @default(PENDING)
  priority       String? // low, medium, high, urgent
  estimatedHours Float?
  actualHours    Float?
  estimatedCost  Float?
  actualCost     Float?
  startDate      DateTime?
  completionDate DateTime?
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  garage    Garage                @relation(fields: [garageId], references: [id], onDelete: Cascade)
  car       Car                   @relation(fields: [carId], references: [id], onDelete: Cascade)
  employee  Employee?             @relation(fields: [employeeId], references: [id])
  tasks     MaintenanceTask[]
  photos    MaintenancePhoto[]
  approvals MaintenanceApproval[]
  invoices  Invoice[]

  @@map("maintenance_jobs")
}

model MaintenanceTask {
  id               String   @id @default(uuid())
  maintenanceJobId String
  title            String
  description      String?
  isCompleted      Boolean  @default(false)
  estimatedMinutes Int?
  actualMinutes    Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  maintenanceJob MaintenanceJob @relation(fields: [maintenanceJobId], references: [id], onDelete: Cascade)

  @@map("maintenance_tasks")
}

model MaintenancePhoto {
  id               String   @id @default(uuid())
  maintenanceJobId String
  url              String
  filename         String? // stored filename on disk (UUID + ext)
  originalName     String? // user's original filename for download attribution
  mimeType         String?
  sizeBytes        Int?
  uploadedBy       String?
  caption          String?
  type             String? // before, during, after
  createdAt        DateTime @default(now())

  maintenanceJob MaintenanceJob @relation(fields: [maintenanceJobId], references: [id], onDelete: Cascade)

  @@map("maintenance_photos")
}

model MaintenanceApproval {
  id               String         @id @default(uuid())
  maintenanceJobId String
  status           ApprovalStatus @default(PENDING)
  requestedAmount  Float?
  description      String?
  respondedAt      DateTime?
  responseNote     String?
  createdAt        DateTime       @default(now())

  maintenanceJob MaintenanceJob @relation(fields: [maintenanceJobId], references: [id], onDelete: Cascade)

  @@map("maintenance_approvals")
}

model Invoice {
  id                 String        @id @default(uuid())
  garageId           String
  customerId         String
  carId              String?
  appointmentId      String?
  maintenanceJobId   String?
  quoteId            String?
  invoiceNumber      String        @unique
  status             InvoiceStatus @default(DRAFT)
  currency           String        @default("TND")
  subtotal           Float         @default(0)
  taxAmount          Float         @default(0)
  discount           Float         @default(0)
  fiscalStamp        Float         @default(1.0)
  total              Float         @default(0)
  dueDate            DateTime?
  paidAt             DateTime?
  lockedAt           DateTime?
  lockedBy           String? // user id who locked the invoice
  issuedNumber       Int? // gapless sequence within fiscal period
  discountReason     String?
  discountApprovedBy String? // user id
  notes              String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  garage            Garage             @relation(fields: [garageId], references: [id], onDelete: Cascade)
  customer          Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  car               Car?               @relation(fields: [carId], references: [id], onDelete: SetNull)
  appointment       Appointment?       @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  maintenanceJob    MaintenanceJob?    @relation(fields: [maintenanceJobId], references: [id], onDelete: SetNull)
  quote             Quote?             @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  lineItems         InvoiceLineItem[]
  payments          Payment[]
  redeemedAiActions AiAction[]         @relation("AiActionRedemption")
  creditNotes       CreditNote[]
  discountAuditLogs DiscountAuditLog[]
  deliveryLogs      DeliveryLog[]

  @@map("invoices")
}

model InvoiceLineItem {
  id          String  @id @default(uuid())
  invoiceId   String
  description String
  quantity    Float   @default(1)
  unitPrice   Float
  total       Float
  type        String? // labor, part, service
  partId      String?
  serviceCode String?
  mechanicId  String?
  laborHours  Float?
  tvaRate     Float   @default(19)
  tvaAmount   Float   @default(0)
  discountPct Float?

  invoice  Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  part     Part?     @relation(fields: [partId], references: [id], onDelete: SetNull)
  mechanic Employee? @relation(fields: [mechanicId], references: [id], onDelete: SetNull)

  @@map("invoice_line_items")
}

model Payment {
  id        String        @id @default(uuid())
  invoiceId String
  amount    Float
  method    PaymentMethod @default(CASH)
  reference String?
  paidAt    DateTime      @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Part {
  id          String   @id @default(uuid())
  garageId    String
  supplierId  String?
  name        String
  partNumber  String?
  category    String?
  description String?
  quantity    Int      @default(0)
  minQuantity Int      @default(5)
  unitPrice   Float    @default(0)
  costPrice   Float    @default(0)
  location    String? // shelf/bin location
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  garage              Garage               @relation(fields: [garageId], references: [id], onDelete: Cascade)
  supplier            Supplier?            @relation(fields: [supplierId], references: [id])
  stockMovements      StockMovement[]
  invoiceLineItems    InvoiceLineItem[]
  quoteLineItems      QuoteLineItem[]
  creditNoteLineItems CreditNoteLineItem[]

  @@map("parts")
}

model Supplier {
  id        String   @id @default(uuid())
  garageId  String
  name      String
  email     String?
  phone     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  garage Garage @relation(fields: [garageId], references: [id], onDelete: Cascade)
  parts  Part[]

  @@map("suppliers")
}

model StockMovement {
  id        String   @id @default(uuid())
  partId    String
  type      String // in, out, adjustment
  quantity  Int
  reason    String?
  reference String?
  createdAt DateTime @default(now())

  part Part @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@map("stock_movements")
}

model Approval {
  id           String         @id @default(uuid())
  garageId     String
  type         ApprovalType
  status       ApprovalStatus @default(PENDING)
  title        String
  description  String?
  amount       Float?
  requestedBy  String
  respondedBy  String?
  respondedAt  DateTime?
  responseNote String?
  metadata     Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  garage Garage @relation(fields: [garageId], references: [id], onDelete: Cascade)

  @@map("approvals")
}

model Notification {
  id        String           @id @default(uuid())
  garageId  String
  userId    String?
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  garage Garage @relation(fields: [garageId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model GarageModule {
  id          String    @id @default(uuid())
  garageId    String
  moduleId    String // calendar, maintenance, invoicing, etc.
  isActive    Boolean   @default(true)
  purchasedAt DateTime  @default(now())
  expiresAt   DateTime?

  garage Garage @relation(fields: [garageId], references: [id], onDelete: Cascade)

  @@unique([garageId, moduleId])
  @@map("garage_modules")
}

model AiAction {
  id                String         @id @default(uuid())
  garageId          String
  customerId        String
  kind              AiActionKind
  status            AiActionStatus @default(DRAFT)
  messageBody       String
  discountKind      DiscountKind?
  discountValue     Float?
  expiresAt         DateTime?
  churnRiskSnapshot Float
  factorsSnapshot   String[]
  providerMessageId String?
  errorMessage      String?
  approvedByUserId  String?
  redeemedInvoiceId String?
  createdAt         DateTime       @default(now())
  approvedAt        DateTime?
  sentAt            DateTime?
  failedAt          DateTime?
  redeemedAt        DateTime?
  updatedAt         DateTime       @updatedAt

  garage          Garage   @relation(fields: [garageId], references: [id], onDelete: Cascade)
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  approvedBy      User?    @relation("AiActionApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  redeemedInvoice Invoice? @relation("AiActionRedemption", fields: [redeemedInvoiceId], references: [id], onDelete: SetNull)

  @@index([customerId, status])
  @@index([garageId, status, createdAt])
  @@map("ai_actions")
}

model AssistantConversation {
  id         String    @id @default(uuid())
  garageId   String
  userId     String
  title      String?
  pinned     Boolean   @default(false)
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  garage    Garage              @relation(fields: [garageId], references: [id], onDelete: Cascade)
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AssistantMessage[]
  toolCalls AssistantToolCall[]

  @@index([garageId, userId, updatedAt])
  @@map("assistant_conversations")
}

model AssistantMessage {
  id             String               @id @default(uuid())
  conversationId String
  role           AssistantMessageRole
  content        String               @db.Text
  toolCallId     String?
  skillUsed      String?
  agentUsed      String?
  tokensIn       Int?
  tokensOut      Int?
  llmProvider    String?
  createdAt      DateTime             @default(now())

  conversation     AssistantConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  toolCall         AssistantToolCall?    @relation("AssistantMessageToolCall", fields: [toolCallId], references: [id], onDelete: SetNull)
  emittedToolCalls AssistantToolCall[]   @relation("AssistantToolCallEmitter")

  @@index([conversationId, createdAt])
  @@map("assistant_messages")
}

model AssistantToolCall {
  id               String                  @id @default(uuid())
  conversationId   String
  messageId        String?
  toolName         String
  argsJson         Json
  resultJson       Json?
  status           AssistantToolCallStatus @default(EXECUTED)
  blastTier        AssistantBlastTier
  approvedByUserId String?
  approvedAt       DateTime?
  expiresAt        DateTime?
  errorMessage     String?
  durationMs       Int?
  createdAt        DateTime                @default(now())

  conversation   AssistantConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  emitter        AssistantMessage?     @relation("AssistantToolCallEmitter", fields: [messageId], references: [id], onDelete: SetNull)
  resultMessages AssistantMessage[]    @relation("AssistantMessageToolCall")
  approvedBy     User?                 @relation("AssistantToolCallApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@index([conversationId, status])
  @@index([status, expiresAt])
  @@map("assistant_tool_calls")
}

// ── Fiscal invoicing models ──────────────────────────────

model Quote {
  id                   String      @id @default(uuid())
  garageId             String
  customerId           String
  carId                String?
  quoteNumber          String      @unique
  status               QuoteStatus @default(DRAFT)
  subtotal             Float       @default(0)
  taxAmount            Float       @default(0)
  discount             Float       @default(0)
  total                Float       @default(0)
  validUntil           DateTime?
  convertedToInvoiceId String?
  notes                String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  garage    Garage          @relation(fields: [garageId], references: [id], onDelete: Cascade)
  customer  Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  car       Car?            @relation(fields: [carId], references: [id], onDelete: SetNull)
  lineItems QuoteLineItem[]
  invoices  Invoice[]

  @@map("quotes")
}

model QuoteLineItem {
  id          String  @id @default(uuid())
  quoteId     String
  description String
  quantity    Float   @default(1)
  unitPrice   Float
  total       Float
  type        String? // labor, part, service
  partId      String?
  serviceCode String?
  mechanicId  String?
  laborHours  Float?
  tvaRate     Float   @default(19)
  tvaAmount   Float   @default(0)
  discountPct Float?

  quote    Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  part     Part?     @relation(fields: [partId], references: [id], onDelete: SetNull)
  mechanic Employee? @relation(fields: [mechanicId], references: [id], onDelete: SetNull)

  @@map("quote_line_items")
}

model CreditNote {
  id               String           @id @default(uuid())
  garageId         String
  invoiceId        String
  creditNoteNumber String           @unique
  reason           String
  status           CreditNoteStatus @default(ISSUED)
  subtotal         Float            @default(0)
  taxAmount        Float            @default(0)
  discount         Float            @default(0)
  total            Float            @default(0)
  restockParts     Boolean          @default(false)
  lockedAt         DateTime
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  garage    Garage               @relation(fields: [garageId], references: [id], onDelete: Cascade)
  invoice   Invoice              @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  lineItems CreditNoteLineItem[]

  @@map("credit_notes")
}

model CreditNoteLineItem {
  id           String  @id @default(uuid())
  creditNoteId String
  description  String
  quantity     Float   @default(1)
  unitPrice    Float
  total        Float
  type         String? // labor, part, service
  partId       String?
  serviceCode  String?
  mechanicId   String?
  laborHours   Float?
  tvaRate      Float   @default(19)
  tvaAmount    Float   @default(0)
  discountPct  Float?

  creditNote CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
  part       Part?      @relation(fields: [partId], references: [id], onDelete: SetNull)
  mechanic   Employee?  @relation(fields: [mechanicId], references: [id], onDelete: SetNull)

  @@map("credit_note_line_items")
}

model InvoiceCounter {
  id         String      @id @default(uuid())
  garageId   String
  kind       CounterKind
  year       Int // 0 if NEVER policy; YYYY for YEARLY; YYYYMM for MONTHLY
  lastIssued Int         @default(0)

  garage Garage @relation(fields: [garageId], references: [id], onDelete: Cascade)

  @@unique([garageId, kind, year])
  @@map("invoice_counters")
}

model ServiceCatalog {
  id                String   @id @default(uuid())
  garageId          String
  code              String
  name              String
  description       String?
  category          String?
  defaultPrice      Float
  defaultLaborHours Float?
  defaultTvaRate    Float    @default(19)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  garage Garage @relation(fields: [garageId], references: [id], onDelete: Cascade)

  @@unique([garageId, code])
  @@map("service_catalog")
}

model DiscountAuditLog {
  id         String   @id @default(uuid())
  invoiceId  String
  percentage Float
  amount     Float
  reason     String
  approvedBy String
  approvedAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("discount_audit_logs")
}

model DeliveryLog {
  id        String          @id @default(uuid())
  invoiceId String
  channel   DeliveryChannel
  recipient String
  sentAt    DateTime?
  status    DeliveryStatus  @default(PENDING)
  error     String?
  viewedAt  DateTime?
  createdAt DateTime        @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("delivery_logs")
}

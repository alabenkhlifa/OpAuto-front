flowchart LR
    START(("Start"))
    END_SUCCESS(("End"))

    START --> OPEN["Open Appointments Page"]
    OPEN --> CLICK["Click 'Add Appointment'"]
    CLICK --> HAS_CAR{"Car Exists?"}

    HAS_CAR -->|"Yes"| SCHEDULE["Schedule Appointment
    (See Diagram 3)"]
    HAS_CAR -->|"No"| HAS_CUSTOMER{"Customer Exists?"}

    HAS_CUSTOMER -->|"No"| CREATE_CUST["Create New Customer
    (See Diagram 1)"]
    HAS_CUSTOMER -->|"Yes"| CREATE_CAR["Register New Car
    (See Diagram 2)"]

    CREATE_CUST --> CREATE_CAR
    CREATE_CAR --> SCHEDULE

    SCHEDULE --> END_SUCCESS


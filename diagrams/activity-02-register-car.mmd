flowchart TD
    START(("Start"))
    END_SUCCESS(("Car Registered"))
    END_CANCEL(("Cancelled"))

    START --> NAV["Navigate to Cars Page"]
    NAV --> CLICK["Click 'Add Car'"]
    CLICK --> FORM["Car Registration Form Opens"]
    FORM -->|"Cancel"| END_CANCEL
    FORM --> FILL["Fill Car Details
    (License Plate, Make, Model, Year)"]
    FILL --> SELECT_OWNER["Select Customer as Owner"]
    SELECT_OWNER --> CHECK_LIMIT{"Car Limit Reached?
    (Subscription Check)"}
    CHECK_LIMIT -->|"Yes"| UPGRADE_PROMPT["Show Upgrade Prompt"]
    UPGRADE_PROMPT --> UPGRADE_DECIDE{"Upgrade?"}
    UPGRADE_DECIDE -->|"No"| END_CANCEL
    UPGRADE_DECIDE -->|"Yes"| UPGRADE["Upgrade Subscription"]
    UPGRADE --> FILL
    CHECK_LIMIT -->|"No"| VALIDATE{"Form Valid?"}
    VALIDATE -->|"No"| FILL
    VALIDATE -->|"Yes"| SAVE["Save Car"]
    SAVE --> END_SUCCESS

    classDef startEnd fill:#4a90d9,stroke:#2c5f8a,color:#fff,stroke-width:3px
    classDef cancel fill:#dc2626,stroke:#b91c1c,color:#fff,stroke-width:2px
    classDef decision fill:#7c3aed,stroke:#5b21b6,color:#fff,stroke-width:2px
    classDef action fill:#1e293b,stroke:#475569,color:#e2e8f0,stroke-width:1px
    classDef success fill:#059669,stroke:#047857,color:#fff,stroke-width:2px
    classDef warning fill:#d97706,stroke:#b45309,color:#fff,stroke-width:2px

    class START startEnd
    class END_SUCCESS success
    class END_CANCEL cancel
    class CHECK_LIMIT,UPGRADE_DECIDE,VALIDATE decision
    class UPGRADE_PROMPT warning

    OWNER --> UC_REJECT

    OWNER --> UC_ADD_PART
    OWNER --> UC_VIEW_INVENTORY
    OWNER --> UC_UPDATE_STOCK
    OWNER --> UC_STOCK_ALERTS

    OWNER --> UC_GARAGE_SETTINGS
    OWNER --> UC_MANAGE_SUBSCRIPTION
    OWNER --> UC_VIEW_DASHBOARD
    STAFF --> UC_VIEW_DASHBOARD

    %% Include relationships
    UC_CREATE_APPT -.->|"<<include>>"| UC_VIEW_CARS
    UC_REGISTER_CAR -.->|"<<include>>"| UC_VIEW_CUSTOMERS
    UC_CREATE_JOB -.->|"<<include>>"| UC_VIEW_CARS
    UC_CREATE_INVOICE -.->|"<<include>>"| UC_VIEW_CUSTOMERS

    %% Extend relationships
    UC_CREATE_APPT -.->|"<<extend>>"| UC_REGISTER_CAR
    UC_REGISTER_CAR -.->|"<<extend>>"| UC_ADD_CUSTOMER
    UC_UPDATE_JOB_STATUS -.->|"<<extend>>"| UC_REQUEST_APPROVAL
    UC_VIEW_INVENTORY -.->|"<<extend>>"| UC_STOCK_ALERTS


            UC_REGISTER_CAR["Register Car"]
            UC_VIEW_CARS["View Cars"]
            UC_EDIT_CAR["Edit Car"]
            UC_DELETE_CAR["Delete Car"]
            UC_SEARCH_CARS["Search Cars"]
            UC_VIEW_CAR_HISTORY["View Car Service History"]
        end

        subgraph CustomerMgmt["Customer Management"]
            UC_ADD_CUSTOMER["Add Customer"]
            UC_VIEW_CUSTOMERS["View Customers"]
            UC_EDIT_CUSTOMER["Edit Customer"]
            UC_DELETE_CUSTOMER["Delete Customer"]
            UC_SEARCH_CUSTOMERS["Search Customers"]
            UC_VIEW_CUST_HISTORY["View Customer History"]
        end

        subgraph MaintenanceMgmt["Maintenance Management"]
            UC_CREATE_JOB["Create Maintenance Job"]
            UC_VIEW_JOBS["View Maintenance Jobs"]
            UC_UPDATE_JOB_STATUS["Update Job Status"]
            UC_ADD_PHOTOS["Add Before/After Photos"]
            UC_REQUEST_APPROVAL["Request Approval"]
        end

        subgraph InvoiceMgmt["Invoice Management"]
            UC_CREATE_INVOICE["Create Invoice"]
            UC_VIEW_INVOICES["View Invoices"]
            UC_RECORD_PAYMENT["Record Payment"]
            UC_SEND_INVOICE["Send Invoice"]
        end

        subgraph EmployeeMgmt["Employee Management"]
            UC_ADD_EMPLOYEE["Add Employee"]
            UC_VIEW_EMPLOYEES["View Employees"]
            UC_EDIT_EMPLOYEE["Edit Employee"]
            UC_VIEW_PERFORMANCE["View Performance Metrics"]
        end

        subgraph ApprovalMgmt["Approval Management"]
            UC_VIEW_APPROVALS["View Approvals"]
            UC_APPROVE["Approve Request"]
            UC_REJECT["Reject Request"]
        end

        subgraph InventoryMgmt["Inventory Management"]
            UC_ADD_PART["Add Part"]
            UC_VIEW_INVENTORY["View Inventory"]
            UC_UPDATE_STOCK["Update Stock"]
            UC_STOCK_ALERTS["View Stock Alerts"]
        end

        subgraph Settings["Settings & Subscription"]
            UC_GARAGE_SETTINGS["Configure Garage Settings"]
            UC_MANAGE_SUBSCRIPTION["Manage Subscription"]
            UC_VIEW_DASHBOARD["View Dashboard Analytics"]
        end

    end

    OWNER(("👤 Owner"))
    STAFF(("👤 Staff"))

    %% Auth - Both roles
    OWNER --> UC_LOGIN
    OWNER --> UC_LOGOUT
    STAFF --> UC_LOGIN
    STAFF --> UC_LOGOUT

    %% Appointments - Both roles
    OWNER --> UC_CREATE_APPT
    OWNER --> UC_VIEW_APPTS
    OWNER --> UC_EDIT_APPT
    OWNER --> UC_DELETE_APPT
    OWNER --> UC_SEARCH_APPTS
    OWNER --> UC_CHANGE_APPT_STATUS
    STAFF --> UC_CREATE_APPT
    STAFF --> UC_VIEW_APPTS
    STAFF --> UC_EDIT_APPT
    STAFF --> UC_DELETE_APPT
    STAFF --> UC_SEARCH_APPTS
    STAFF --> UC_CHANGE_APPT_STATUS

    %% Cars - Both roles
    OWNER --> UC_REGISTER_CAR
    OWNER --> UC_VIEW_CARS
    OWNER --> UC_EDIT_CAR
    OWNER --> UC_DELETE_CAR
    OWNER --> UC_SEARCH_CARS
    OWNER --> UC_VIEW_CAR_HISTORY
    STAFF --> UC_REGISTER_CAR
    STAFF --> UC_VIEW_CARS
    STAFF --> UC_EDIT_CAR
    STAFF --> UC_DELETE_CAR
    STAFF --> UC_SEARCH_CARS
    STAFF --> UC_VIEW_CAR_HISTORY


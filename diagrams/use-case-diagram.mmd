    STAFF --> UC_ADD_CUSTOMER
    STAFF --> UC_VIEW_CUSTOMERS
    STAFF --> UC_EDIT_CUSTOMER
    STAFF --> UC_DELETE_CUSTOMER
    STAFF --> UC_SEARCH_CUSTOMERS
    STAFF --> UC_VIEW_CUST_HISTORY

    %% Maintenance - Both roles
    OWNER --> UC_CREATE_JOB
    OWNER --> UC_VIEW_JOBS
    OWNER --> UC_UPDATE_JOB_STATUS
    OWNER --> UC_ADD_PHOTOS
    STAFF --> UC_CREATE_JOB
    STAFF --> UC_VIEW_JOBS
    STAFF --> UC_UPDATE_JOB_STATUS
    STAFF --> UC_ADD_PHOTOS
    STAFF --> UC_REQUEST_APPROVAL

    %% Owner-only features
    OWNER --> UC_CREATE_INVOICE
    OWNER --> UC_VIEW_INVOICES
    OWNER --> UC_RECORD_PAYMENT
    OWNER --> UC_SEND_INVOICE

    OWNER --> UC_ADD_EMPLOYEE
    OWNER --> UC_VIEW_EMPLOYEES
    OWNER --> UC_EDIT_EMPLOYEE
    OWNER --> UC_VIEW_PERFORMANCE

    OWNER --> UC_VIEW_APPROVALS

    classDef actor fill:#4a90d9,stroke:#2c5f8a,color:#fff,stroke-width:2px
    classDef usecase fill:#1e293b,stroke:#475569,color:#e2e8f0,stroke-width:1px
    classDef system fill:#0f172a,stroke:#334155,color:#94a3b8

    class OWNER,STAFF actor
    class UC_LOGIN,UC_LOGOUT,UC_CREATE_APPT,UC_VIEW_APPTS,UC_EDIT_APPT,UC_DELETE_APPT,UC_SEARCH_APPTS,UC_CHANGE_APPT_STATUS usecase
    class UC_REGISTER_CAR,UC_VIEW_CARS,UC_EDIT_CAR,UC_DELETE_CAR,UC_SEARCH_CARS,UC_VIEW_CAR_HISTORY usecase
    class UC_ADD_CUSTOMER,UC_VIEW_CUSTOMERS,UC_EDIT_CUSTOMER,UC_DELETE_CUSTOMER,UC_SEARCH_CUSTOMERS,UC_VIEW_CUST_HISTORY usecase
    class UC_CREATE_JOB,UC_VIEW_JOBS,UC_UPDATE_JOB_STATUS,UC_ADD_PHOTOS,UC_REQUEST_APPROVAL usecase
    class UC_CREATE_INVOICE,UC_VIEW_INVOICES,UC_RECORD_PAYMENT,UC_SEND_INVOICE usecase
